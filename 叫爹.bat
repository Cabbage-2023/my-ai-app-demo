@echo off
:: 1. 强制 CMD 使用 UTF-8 编码，解决乱码问题
chcp 65001 >nul
setlocal

:: -----------------------------------------
:: 2. 路径判定逻辑
:: -----------------------------------------
if "%~1"=="" (
    set "TARGET_DIR=%~dp0"
    echo [状态] 直接双击启动
) else (
    set "TARGET_DIR=%~1"
    echo [状态] 文件夹拖拽启动
)

cd /d "%TARGET_DIR%"

:: -----------------------------------------
:: 3. 配置代理
:: -----------------------------------------
set HTTP_PROXY=http://127.0.0.1:7890
set HTTPS_PROXY=http://127.0.0.1:7890

echo ============================================
echo   🚀 Claude Code 智能启动器
echo --------------------------------------------
echo   代理地址: %HTTP_PROXY%
echo   当前项目: %cd%
echo ============================================

:: -----------------------------------------
:: 4. 运行 Claude
:: -----------------------------------------
call claude

echo.
echo --------------------------------------------
echo Claude 已退出。窗口将保持开启以供调试。
cmd /k