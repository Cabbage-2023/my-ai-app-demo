# ── 国内镜像（服务器 Docker 构建加速） ──
registry=https://registry.npmmirror.com

# ── pnpm 11 构建许可 ──
allowBuilds[esbuild]=true
allowBuilds[sharp]=true
allowBuilds[unrs-resolver]=true
# 生产环境用 SiliconFlow API，跳过 onnxruntime GPU 包 + puppeteer Chromium
# allowBuilds[onnxruntime-node]=true
# allowBuilds[puppeteer]=true
